root = true

# All files
[*]
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# Java files
[*.java]
indent_size = 4
max_line_length = 120

# XML files
[*.xml]
indent_size = 2

# YAML files
[*.{yaml,yml}]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_size = 2

# Properties files
[*.properties]
indent_size = 2

# Feature files (Gherkin)
[*.feature]
indent_size = 2
